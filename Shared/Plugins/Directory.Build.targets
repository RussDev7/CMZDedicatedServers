<Project>
  <Target Name="CopySharedPluginToServerOutputs" AfterTargets="Build">
    <PropertyGroup>
      <RepoRoot>$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)\..\..\..'))</RepoRoot>

      <PluginFolderName Condition="'$(PluginFolderName)' == ''">$(AssemblyName)</PluginFolderName>

      <LidgrenPluginDir>$(RepoRoot)\Build\CMZDedicatedLidgrenServer\Plugins\$(PluginFolderName)\</LidgrenPluginDir>
      <SteamPluginDir>$(RepoRoot)\Build\CMZDedicatedSteamServer\Plugins\$(PluginFolderName)\</SteamPluginDir>

      <LidgrenPluginDependencyDir>$(LidgrenPluginDir)Dependencies\</LidgrenPluginDependencyDir>
      <SteamPluginDependencyDir>$(SteamPluginDir)Dependencies\</SteamPluginDependencyDir>
    </PropertyGroup>

    <!-- Main plugin files stay in the plugin root. -->
    <ItemGroup>
      <PluginMainFiles Include="$(TargetPath)" />
      <PluginMainFiles Include="$(TargetDir)$(TargetName).pdb" Condition="Exists('$(TargetDir)$(TargetName).pdb')" />
      <PluginMainFiles Include="$(TargetDir)$(TargetName).xml" Condition="Exists('$(TargetDir)$(TargetName).xml')" />
    </ItemGroup>

    <!-- Dependency DLLs, if any. -->
    <ItemGroup>
      <PluginDependencyFiles Include="@(ReferenceCopyLocalPaths)"
                             Condition="'%(ReferenceCopyLocalPaths.Extension)' == '.dll'" />

      <!-- Do not copy the shared server plugin API beside each plugin. -->
      <PluginDependencyFiles Remove="@(PluginDependencyFiles)"
                             Condition="'%(Filename)' == 'CastleForge.ServerPluginAPI'" />

      <PluginDependencyFiles Remove="@(PluginDependencyFiles)"
                             Condition="'%(Filename)' == 'CMZDedicatedServer.PluginAPI'" />
    </ItemGroup>

    <MakeDir Directories="$(LidgrenPluginDir)" />
    <MakeDir Directories="$(SteamPluginDir)" />

    <Copy SourceFiles="@(PluginMainFiles)"
          DestinationFolder="$(LidgrenPluginDir)"
          SkipUnchangedFiles="true" />

    <Copy SourceFiles="@(PluginMainFiles)"
          DestinationFolder="$(SteamPluginDir)"
          SkipUnchangedFiles="true" />

    <!-- Only create Dependencies/ when there are dependency DLLs to copy. -->
    <MakeDir Directories="$(LidgrenPluginDependencyDir)"
             Condition="'@(PluginDependencyFiles)' != ''" />

    <MakeDir Directories="$(SteamPluginDependencyDir)"
             Condition="'@(PluginDependencyFiles)' != ''" />

    <Copy SourceFiles="@(PluginDependencyFiles)"
          DestinationFolder="$(LidgrenPluginDependencyDir)"
          SkipUnchangedFiles="true"
          Condition="'@(PluginDependencyFiles)' != ''" />

    <Copy SourceFiles="@(PluginDependencyFiles)"
          DestinationFolder="$(SteamPluginDependencyDir)"
          SkipUnchangedFiles="true"
          Condition="'@(PluginDependencyFiles)' != ''" />
  </Target>
</Project>